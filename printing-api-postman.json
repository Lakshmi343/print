                {
                    "name": "Dynamic Entities CRUD",
                    "description": "These endpoints use the 'entity' variable which can be any of the following: menuItems, categories, services, highlights, testimonials, ctaButtons.",
                    "item": [
                        {
                            "name": "Get All Entities",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{admin_token}}"
                                    }
                                ],
                                "url": {
                                    "raw": "{{baseUrl}}/admin/{{entity}}",
                                    "host": [
                                        "{{baseUrl}}"
                                    ],
                                    "path": [
                                        "admin",
                                        "{{entity}}"
                                    ],
                                    "description": "Gets all items for the given entity type."
                                }
                            },
                            "response": []
                        },
                        {
                            "name": "Create Entity",
                            "request": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{admin_token}}"
                                    },
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"label\": \"New Item\",\n    \"title\": \"Example Title\",\n    \"description\": \"Item description\",\n    \"active\": true\n}"
                                },
                                "url": {
                                    "raw": "{{baseUrl}}/admin/{{entity}}",
                                    "host": [
                                        "{{baseUrl}}"
                                    ],
                                    "path": [
                                        "admin",
                                        "{{entity}}"
                                    ]
                                }
                            },
                            "response": []
                        },
                        {
                            "name": "Update Entity",
                            "request": {
                                "method": "PUT",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{admin_token}}"
                                    },
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"label\": \"Updated Item\"\n}"
                                },
                                "url": {
                                    "raw": "{{baseUrl}}/admin/{{entity}}/:id",
                                    "host": [
                                        "{{baseUrl}}"
                                    ],
                                    "path": [
                                        "admin",
                                        "{{entity}}",
                                        ":id"
                                    ],
                                    "variable": [
                                        {
                                            "key": "id",
                                            "value": "REPLACE_WITH_ITEM_ID"
